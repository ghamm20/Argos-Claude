{
  "name": "argos-claude",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "telemetry-off": "next telemetry disable",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "verify": "node scripts/verify-argos.mjs",
    "check": "npm run lint && npm run typecheck && npm run build && npm run verify",
    "check:full": "node scripts/check-full.mjs",
    "smoke": "npm run verify",
    "smoke:launcher-e2e": "node scripts/smoke-launcher-e2e.mjs",
    "warm": "node scripts/warm-ollama.mjs",
    "demo-check": "node scripts/demo-check.mjs",
    "demo-prep": "node scripts/demo-check.mjs && node -e \"console.log('\\n  Open: http://127.0.0.1:7799  (launch via ARGOS\\\\launcher.bat from your USB)')\""
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "11.11.17",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "next": "14.2.18",
    "pdf-parse": "^2.4.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/node": "20.17.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3"
  }
